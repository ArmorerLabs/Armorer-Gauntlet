# Armorer Gauntlet local setup defaults.
# Copy to .env or run `make setup` to create a populated file.

PWA_PORT=3000
RELAY_PORT=8787
FRONT_DOOR_PORT=8080

# The local daemon reads this URL when you run `make daemon`.
# For `make tunnel`, use the printed wss://.../relay URL instead.
RELAY_URL=ws://127.0.0.1:8787

# Used by the PWA build and by the relay for generic push notifications.
# `make setup` generates these values without overwriting existing ones.
VAPID_SUBJECT=mailto:you@example.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
PUBLIC_VAPID_PUBLIC_KEY=
