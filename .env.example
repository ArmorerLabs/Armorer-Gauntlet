# Armorer Gauntlet local setup defaults.
# Copy to .env or run `make setup` to create a populated file.

PWA_PORT=3000
RELAY_PORT=8787
FRONT_DOOR_PORT=8080

# The local daemon reads this URL when you run `make daemon`.
# For `make tunnel`, use the printed wss://.../relay URL instead.
RELAY_URL=ws://127.0.0.1:8787

# Optional Pi coding-agent adapter settings. Pi's tool runtime needs a modern
# Node binary when your login shell still resolves `node` to an older version.
# `make setup` auto-detects this on common nvm/Homebrew installs when possible.
PI_NODE_BIN_DIR=
PI_CLI_ARGS=

# Optional Claude Code adapter settings. Leave the path empty to use `claude`
# from PATH. Extra args are passed before the prompt, for example:
# CLAUDE_CODE_CLI_ARGS=--permission-mode acceptEdits
CLAUDE_CODE_CLI_PATH=
CLAUDE_CODE_CLI_ARGS=
CLAUDE_GAUNTLET_SESSION_DIR=

# Used by the PWA build and by the relay for generic push notifications.
# `make setup` generates these values without overwriting existing ones.
VAPID_SUBJECT=mailto:you@example.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
PUBLIC_VAPID_PUBLIC_KEY=
