{
  "name": "@armorer/gauntlet-daemon",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "armorer-gauntlet-daemon": "./dist/index.js"
  },
  "scripts": {
    "dev": "node ../../scripts/build-libs.mjs && tsx src/index.ts start --relay ws://127.0.0.1:8787",
    "build": "node ../../scripts/build-libs.mjs && tsc -p tsconfig.json",
    "check": "node ../../scripts/build-libs.mjs && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@armorer/gauntlet-codex-protocol": "0.1.0",
    "@armorer/gauntlet-shared": "0.1.0",
    "commander": "^13.1.0",
    "qrcode-terminal": "^0.12.0",
    "ws": "^8.18.2"
  },
  "devDependencies": {
    "tsx": "^4.19.4"
  }
}
